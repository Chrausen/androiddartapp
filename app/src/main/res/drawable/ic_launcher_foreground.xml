<?xml version="1.0" encoding="utf-8"?>
<!--
  Dartboard bullseye icon — foreground layer for adaptive icon.
  Canvas: 108×108 dp  |  Safe zone: 66×66 dp (radius 33 from centre 54,54)
  All circles fit within r=34 to stay inside the safe zone.

  Colour scheme (matches app theme):
    Rings : #F0F0EE  (TextPrimary — near-white)
    Gaps  : #16181C  (Surface — matches background layer)
    Centre: #E8FF47  (Accent)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer white ring (r=34) -->
    <path
        android:fillColor="#F0F0EE"
        android:pathData="M54,20 A34,34 0 1,1 54,88 A34,34 0 1,1 54,20 Z" />

    <!-- Dark gap (r=27) -->
    <path
        android:fillColor="#16181C"
        android:pathData="M54,27 A27,27 0 1,1 54,81 A27,27 0 1,1 54,27 Z" />

    <!-- Middle white ring (r=20) -->
    <path
        android:fillColor="#F0F0EE"
        android:pathData="M54,34 A20,20 0 1,1 54,74 A20,20 0 1,1 54,34 Z" />

    <!-- Dark gap (r=13) -->
    <path
        android:fillColor="#16181C"
        android:pathData="M54,41 A13,13 0 1,1 54,67 A13,13 0 1,1 54,41 Z" />

    <!-- Accent bullseye (r=7) -->
    <path
        android:fillColor="#E8FF47"
        android:pathData="M54,47 A7,7 0 1,1 54,61 A7,7 0 1,1 54,47 Z" />

</vector>
