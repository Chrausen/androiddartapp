<?xml version="1.0" encoding="utf-8"?>
<!--
  Data extraction rules for Android 12+ (API 31+).
  The Room database is excluded from cloud backup and device-to-device transfer
  to prevent restoring a stale or mismatched database onto a fresh install.
  SharedPreferences (language, settings) are included so user preferences persist.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="clubdarts.db"/>
        <exclude domain="database" path="clubdarts.db-shm"/>
        <exclude domain="database" path="clubdarts.db-wal"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="clubdarts.db"/>
        <exclude domain="database" path="clubdarts.db-shm"/>
        <exclude domain="database" path="clubdarts.db-wal"/>
    </device-transfer>
</data-extraction-rules>
